{
  "name": "wipflow",
  "version": "2.5.0",
  "description": "WIP Flow — single-file offline-first lab WIP tracker",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm test && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^2.1.0",
    "playwright": "^1.60.0",
    "vitest": "^2.1.0"
  }
}
