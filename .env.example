# WIP Flow — secrets template. Copy to `.env` and fill in real values.
# The real `.env` is git-ignored; this `.env.example` is safe to commit (no secrets).
#
# GitHub Personal Access Token with `repo` scope on metrology-dev/WIPflow.
# Generate at: https://github.com/settings/tokens
GITHUB_USER=metrology-dev
GITHUB_TOKEN=

# Git author identity used for commits
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# Token-authenticated push URL (optional convenience)
GIT_REMOTE_URL=https://github.com/metrology-dev/WIPflow.git
